<%- include('partials/header', { title: 'Dashboard' }) %>

<section class="page-intro">
  <div>
    <span class="eyebrow">Overview</span>
    <h1>Dashboard</h1>
    <p>Quick insight into system modules and usage.</p>
  </div>

  <!-- Dark Mode Toggle -->
  <button onclick="toggleTheme()" class="btn">🌙 Toggle Mode</button>
</section>

<div class="grid dashboard-grid">

  <!-- ADMIN -->
  <% if (currentUser.role === 'admin') { %>

    <div class="card stat-card">
      <h3>Total Users</h3>
      <p><%= dashboardData.totalUsers %></p>
    </div>

    <div class="card stat-card">
      <h3>Total Projects</h3>
      <p><%= dashboardData.totalProjects %></p>
    </div>

    <div class="card nav-card">
      <h3>Manage Clients</h3>
      <a href="/admin/clients" class="btn">Open</a>
    </div>

    <div class="card nav-card">
      <h3>Manage Projects</h3>
      <a href="/admin/projects" class="btn">Open</a>
    </div>

    <div class="card nav-card">
      <h3>Manage Tasks</h3>
      <a href="/admin/tasks" class="btn">Open</a>
    </div>

    <div class="card nav-card">
      <h3>Manage Users</h3>
      <a href="/admin/users" class="btn">Open</a>
    </div>

  <% } %>

  <!-- MANAGER -->
  <% if (currentUser.role === 'manager') { %>

    <div class="card stat-card">
      <h3>Pending Approvals</h3>
      <p><%= dashboardData.pendingApprovals %></p>
    </div>

    <div class="card nav-card">
      <h3>Approvals</h3>
      <a href="/approvals" class="btn">Open</a>
    </div>

    <div class="card nav-card">
      <h3>Reports</h3>
      <a href="/reports" class="btn">Open</a>
    </div>

  <% } %>

  <!-- RESOURCE -->
  <% if (currentUser.role === 'resource') { %>

    <div class="card stat-card">
      <h3>Timesheet Status</h3>

      <% if (dashboardData.latestTimesheet) { %>
        <p><%= dashboardData.latestTimesheet.status %></p>
      <% } else { %>
        <p>No timesheet yet</p>
      <% } %>

    </div>

    <div class="card nav-card">
      <h3>Fill Timesheet</h3>
      <a href="/timesheet/new" class="btn">Create</a>
    </div>

  <% } %>

</div>

<script>
function toggleTheme() {
  document.body.classList.toggle('dark-mode');
}
</script>

<%- include('partials/footer') %>