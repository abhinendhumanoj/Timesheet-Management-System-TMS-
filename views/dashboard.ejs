<%- include('partials/header', { title: title }) %>
<section class="page-intro">
  <div>
    <span class="eyebrow">Overview</span>
    <h1>Dashboard</h1>
    <p>Quick insight into team utilization, approvals, and current timesheet progress.</p>
  </div>
</section>

<div class="grid dashboard-grid">
  <% if (currentUser.role === 'admin') { %>
    <div class="card stat-card accent-indigo">
      <div class="stat-icon">👥</div>
      <div>
        <h3>Total Users</h3>
        <p><%= dashboardData.totalUsers %></p>
        <span class="stat-meta">Active users across all roles</span>
      </div>
    </div>
    <div class="card stat-card accent-cyan">
      <div class="stat-icon">📁</div>
      <div>
        <h3>Total Projects</h3>
        <p><%= dashboardData.totalProjects %></p>
        <span class="stat-meta">Projects available for time logging</span>
      </div>
    </div>
  <% } %>

  <% if (currentUser.role === 'manager') { %>
    <div class="card stat-card accent-indigo">
      <div class="stat-icon">✅</div>
      <div>
        <h3>Pending Approvals</h3>
        <p><%= dashboardData.pendingApprovals %></p>
        <span class="stat-meta">Submitted timesheets waiting for action</span>
      </div>
    </div>
  <% } %>

  <% if (currentUser.role === 'resource') { %>
    <div class="card stat-card accent-cyan">
      <div class="stat-icon">⏱️</div>
      <div>
        <h3>Current Timesheet Status</h3>
        <% if (dashboardData.latestTimesheet) { %>
          <p><%= dashboardData.latestTimesheet.status %></p>
          <span class="stat-meta">Week of <%= dashboardData.latestTimesheet.week %></span>
        <% } else { %>
          <p>No timesheet</p>
          <span class="stat-meta">Start your first weekly timesheet</span>
        <% } %>
      </div>
    </div>
  <% } %>
</div>
<%- include('partials/footer') %>
