<%- include('../partials/header', { title }) %>
<div class="page-header">
  <h1>My Timesheets</h1>
  <a class="button-link" href="/timesheet/new">Create / Open Current Week</a>
</div>
<div class="card">
  <table>
    <thead>
      <tr><th>Week</th><th>Status</th><th>Reason</th><th>Action</th></tr>
    </thead>
    <tbody>
      <% timesheets.forEach((timesheet) => { %>
        <tr>
          <td><%= timesheet.week %></td>
          <td><%= timesheet.status %></td>
          <td><%= timesheet.rejection_reason || '-' %></td>
          <td>
            <a href="/timesheet/new?week=<%= timesheet.week %>">Open</a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('../partials/footer') %>
