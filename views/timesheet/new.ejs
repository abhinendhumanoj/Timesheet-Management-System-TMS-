<%- include('../partials/header', { title: 'Weekly Timesheet' }) %>

<section class="page-intro">
  <div>
    <span class="eyebrow">Time tracking</span>
    <h1>Weekly Timesheet</h1>
    <p>Capture daily work and submit your week.</p>
  </div>
</section>

<div class="two-column timesheet-layout">

  <!-- LEFT SIDE -->
  <div class="card form-card">
    <div class="card-header">
      <h2>Week of <%= week %></h2>
      <p>Status:
        <strong><%= timesheet.status %></strong>
      </p>
    </div>

    <% if (timesheet.status === 'Draft') { %>

      <form method="POST" action="/timesheet/add" class="form-stack">
        <input type="hidden" name="timesheet_id" value="<%= timesheet.id %>">
        <input type="hidden" name="week" value="<%= week %>">

        <label>Date</label>
        <input type="date" name="date" required>

        <label>Project</label>
        <select name="project_id" required>
          <option value="">Select project</option>
          <% projects.forEach((project) => { %>
            <option value="<%= project.id %>"><%= project.name %></option>
          <% }) %>
        </select>

        <label>Task</label>
        <select name="task_id" required>
          <option value="">Select task</option>
          <% tasks.forEach((task) => { %>
            <option value="<%= task.id %>"><%= task.name %></option>
          <% }) %>
        </select>

        <label>Hours</label>
        <input type="number" name="hours" step="0.5" min="0.5" max="24" required>

        <label>
          <input type="checkbox" name="billable" value="1"> Billable
        </label>

        <button type="submit" class="btn btn-primary">Add Entry</button>
      </form>

      <form method="POST" action="/timesheet/submit">
        <input type="hidden" name="timesheet_id" value="<%= timesheet.id %>">
        <button type="submit" class="btn">Submit Timesheet</button>
      </form>

    <% } else { %>
      <p>This timesheet is locked.</p>
    <% } %>

  </div>

  <!-- RIGHT SIDE -->
  <div class="card table-card">
    <h2>Entries</h2>

    <table class="table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Project</th>
          <th>Task</th>
          <th>Hours</th>
          <th>Billable</th>
          <th>Action</th>
        </tr>
      </thead>

      <tbody>
        <% entries.forEach((entry) => { %>
          <tr>
            <td><%= entry.date %></td>
            <td><%= entry.project_name %></td>
            <td><%= entry.task_name %></td>
            <td><%= entry.hours %></td>
            <td><%= entry.billable ? 'Yes' : 'No' %></td>

            <td>
              <% if (timesheet.status === 'Draft') { %>
                <a href="/timesheet/edit/<%= entry.id %>">Edit</a>

                <form method="POST" action="/timesheet/delete-entry">
                  <input type="hidden" name="entry_id" value="<%= entry.id %>">
                  <input type="hidden" name="timesheet_id" value="<%= timesheet.id %>">
                  <button type="submit">Delete</button>
                </form>
              <% } else { %>
                -
              <% } %>
            </td>

          </tr>
        <% }) %>
      </tbody>
    </table>

  </div>

</div>

<%- include('../partials/footer') %>