<%- include('../partials/header', { title: 'Edit Entry' }) %>
<%- include('../partials/header', { title: title }) %>
<%- include('../partials/header', { title }) %>

<section class="page-intro">
  <div>
    <span class="eyebrow">Time tracking</span>
    <h1>Edit Entry</h1>
    <p>Refine your draft entry before submitting the week for approval.</p>
  </div>
</section>

<div class="card form-card narrow-card">
  <form method="POST" action="/timesheet/update-entry" class="form-stack">
    <input type="hidden" name="entry_id" value="<%= entry.id %>">
    <input type="hidden" name="timesheet_id" value="<%= timesheet.id %>">

    <div class="field-group">
      <label>Date</label>
      <input type="date" name="date" value="<%= entry.date %>" required>
    </div>

    <div class="field-group">
      <label>Project</label>
      <select name="project_id" required>
        <% projects.forEach((project) => { %>
          <option value="<%= project.id %>" <%= project.id === entry.project_id ? 'selected' : '' %>><%= project.name %></option>
        <% }) %>
      </select>
    </div>

    <div class="field-group">
      <label>Task</label>
      <select name="task_id" required>
        <% tasks.forEach((task) => { %>
          <option value="<%= task.id %>" <%= task.id === entry.task_id ? 'selected' : '' %>><%= task.name %> (<%= task.project_name %>)</option>
        <% }) %>
      </select>
    </div>

    <div class="field-group">
      <label>Hours</label>
      <input type="number" name="hours" step="0.5" min="0.5" max="24" value="<%= entry.hours %>" required>
    </div>

    <label class="checkbox-label card-inline-toggle">
      <input type="checkbox" name="billable" value="1" <%= entry.billable ? 'checked' : '' %>>
      <span>Billable entry</span>
    </label>

    <div class="action-row">
      <button type="submit" class="btn btn-primary">Update Entry</button>
      <a class="btn btn-ghost" href="/timesheet/new?week=<%= timesheet.week %>">Back</a>
    </div>

