<%- include('../partials/header', { title: 'Tasks' }) %>
<section class="page-intro">
  <div>
    <span class="eyebrow">Admin workspace</span>
    <h1>Task Management</h1>
    <p>Organize deliverables and activities under the right projects.</p>
  </div>
</section>

<div class="two-column">
  <div class="card form-card">
    <div class="card-header">
      <h2>Create Task</h2>
      <p>Define reusable tasks for timesheet entry.</p>
    </div>
    <form method="POST" action="/admin/tasks" class="form-stack">
      <div class="field-group">
        <label>Task Name</label>
        <input type="text" name="name" placeholder="e.g. Development" required>
      </div>

      <div class="field-group">
        <label>Project</label>
        <select name="project_id" required>
          <option value="">Select project</option>
          <% projects.forEach((project) => { %>
            <option value="<%= project.id %>"><%= project.name %></option>
          <% }) %>
        </select>
      </div>

      <button type="submit" class="btn btn-primary">Create Task</button>
    </form>
  </div>

  <div class="card table-card">
    <div class="card-header">
      <h2>Tasks</h2>
      <p>Reusable tasks available to your teams.</p>
    </div>
    <div class="table-wrap">
      <table class="table">
        <thead><tr><th>Name</th><th>Project</th></tr></thead>
        <tbody>
          <% tasks.forEach((task) => { %>
            <tr><td><%= task.name %></td><td><%= task.project_name %></td></tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
