<%- include('partials/header', { title }) %>
<h1>Hours Report</h1>
<div class="card">
  <table>
    <thead>
      <tr><th>User</th><th>Email</th><th>Total Hours</th></tr>
    </thead>
    <tbody>
      <% report.forEach((row) => { %>
        <tr>
          <td><%= row.user_name %></td>
          <td><%= row.email %></td>
          <td><%= row.total_hours %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('partials/footer') %>
